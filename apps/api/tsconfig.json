{
  "extends": "@neko/tsconfig/node.json",
  "compilerOptions": {
    "baseUrl": ".",
    "types": ["vitest/globals"],
    "paths": {
      "@/*": ["src/*"],
      "test/*": ["src/test/*"]
    }
  },
  "include": [
    "src/app.ts",
    "src/server.ts",
    "src/@types/**/*.ts",
    "src/utils/**/*.ts",
    "src/core/**/*.ts",
    "src/domain/**/*.ts",
    "src/lib/**/*.ts",
    "src/infra/**/*.ts",
    "generated",
    "test/**/*.ts"
  ],
  "exclude": [
    "src/**/*.js"
  ]
}
